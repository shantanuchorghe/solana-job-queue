FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install production dependencies
RUN npm ci --omit=dev

# Copy worker source and shared code
COPY client/ ./client/
COPY shared/ ./shared/
COPY tsconfig.json ./

# The worker keypair is mounted as a secret at /run/secrets/worker-keypair.json
# or set via WALLET_JSON env var at runtime.

# Start the worker
CMD ["npx", "ts-node", "--esm", "client/worker.ts"]
